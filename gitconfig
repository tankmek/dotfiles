    email = michael@edie.io
    signingkey = B94FEF97E49C9A75

[core]
    editor = vim
    pager = delta || less -FRX
    whitespace = space-before-tab,-indent-with-non-tab,trailing-space

[init]
    defaultBranch = main

[interactive]
    diffFilter = delta --color-only

[color]
    ui = auto

[alias]
    co = checkout
    br = branch
    st = status
    ci = commit
    amend = !git add -A && git commit --amend --no-edit
    # Short pretty log
    lg = log --graph --pretty=format:'%C(bold blue)%h%Creset %C(green)(%ar)%Creset %C(white)%s%Creset %C(dim white)- %an%Creset' --abbrev-commit
    # Graphical detailed log
    gg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(cyan)<%an>%Creset' --abbrev-commit --date=relative
    # Quickly see last commit diff
    last = log -1 --stat
    # Undo last commit but keep changes
    uncommit = reset --soft HEAD^

[delta]
    syntax-theme = gruvbox-dark
    navigate = true
    light = false
    line-numbers = true
    side-by-side = true
    decorations = true
    file-style = bold yellow ul
    file-decoration-style = yellow ol
    hunk-header-style = file line-number syntax
    hunk-header-decoration-style = blue box
    whitespace-error-style = 22 reverse

[merge]
    conflictstyle = zdiff3
    ff = only

[diff]
    colorMoved = default
    mnemonicprefix = true
    algorithm = histogram

[gpg]
    program = gpg2

[commit]
    gpgsign = false

[push]
    autoSetupRemote = true

[pull]
    rebase = true

[fetch]
    prune = true

[rerere]
    enabled = true

[column]
    ui = auto

[branch]
    sort = -committerdate

[tag]
    sort = -version:refname

[url "git@github.com:"]
    insteadOf = https://github.com/

[safe]
    directory = *

# OS-specific settings (credential helpers, etc.)
[includeIf "gitdir:/Users/"]
    path = ~/.gitconfig-macos

[includeIf "gitdir:/home/"]
    path = ~/.gitconfig-linux
